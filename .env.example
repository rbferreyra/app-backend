# ─────────────────────────────────────────────
# Docker Port Mapping
# ─────────────────────────────────────────────
FORWARD_APP_PORT=80
FORWARD_VITE_PORT=5173
FORWARD_REDIS_PORT=6380
DB_PORT=3306

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_NAME="RealEstate"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR

# ─────────────────────────────────────────────
# Frontend URL
# ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=realestate-db
DB_PORT=3306
DB_DATABASE=realestate
DB_USERNAME=forge
DB_PASSWORD=secret

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=realestate-redis
REDIS_PASSWORD=secret
REDIS_PORT=6379

# ─────────────────────────────────────────────
# Cache / Queue / Session
# ─────────────────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# ─────────────────────────────────────────────
# Mail (configure per environment)
# ─────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@realestate.test"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────────
# Sanctum
# ─────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
